using io;

int side() {
  io::out("side\n");
  return 1;
}

int main() {
  io::out("{}\n", true && true);
  io::out("{}\n", true && false);
  io::out("{}\n", false && true);
  io::out("{}\n", true || false);
  io::out("{}\n", false || true);
  io::out("{}\n", false || false);
  io::out("{}\n", !true);
  io::out("{}\n", !false);
  io::out("short-circuit:\n");
  if false && side() > 0 {}
  if true || side() > 0 {}
  io::out("done\n");
  return 0;
}
