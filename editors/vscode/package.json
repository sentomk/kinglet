{
  "name": "kinglet",
  "displayName": "Kinglet",
  "description": "Kinglet language support — syntax highlighting, diagnostics, LSP",
  "version": "0.0.1",
  "publisher": "kinglet",
  "repository": {
    "type": "git",
    "url": "https://github.com/sentomk/kinglet"
  },
  "license": "MIT",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onLanguage:kinglet"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kinglet",
        "aliases": [
          "Kinglet",
          "kinglet"
        ],
        "extensions": [
          ".kl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kinglet",
        "scopeName": "source.kinglet",
        "path": "./kinglet.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Kinglet",
      "properties": {
        "kinglet.server.path": {
          "type": "string",
          "default": "kinglet-lsp",
          "description": "Path to the kinglet-lsp executable"
        }
      }
    },
    "iconThemes": [
      {
        "id": "kinglet-icons",
        "label": "Kinglet File Icons",
        "path": "./kinglet-icon-theme.json"
      }
    ]
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "deploy": "npx @vscode/vsce package && code --install-extension kinglet-0.0.1.vsix"
  },
  "keywords": [],
  "author": "",
  "type": "commonjs",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
