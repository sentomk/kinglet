{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kinglet",
  "scopeName": "source.kinglet",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#namespace-access"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kinglet",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kinglet",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kinglet",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kinglet",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.kinglet",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.kinglet",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.kinglet",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.kinglet",
          "match": "\\b0[bB][01_]+\\b"
        },
        {
          "name": "constant.numeric.float.kinglet",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?[fF]?\\b"
        },
        {
          "name": "constant.numeric.float.kinglet",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*[fF]?\\b"
        },
        {
          "name": "constant.numeric.integer.kinglet",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kinglet",
          "match": "\\b(if|else|for|while|break|continue|return|inspect|when|match|spawn|select)\\b"
        },
        {
          "name": "keyword.declaration.kinglet",
          "match": "\\b(const|mut|import|export|namespace|using|struct|enum|trait|alias)\\b"
        },
        {
          "name": "keyword.operator.word.kinglet",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.kinglet",
          "match": "\\b(int|float|double|bool|string|void|byte|auto)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.kinglet",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.kinglet",
          "match": "\\bnull\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kinglet",
          "match": "::|=>|->|\\+\\+|--|&&|\\|\\||==|!=|<=|>=|<<|>>|[+\\-*/%&|^~!<>=]|\\+=|-=|\\*=|/=|%="
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.kinglet",
          "match": "\\b\\w+(?=\\s*\\()",
          "captures": {
            "0": {
              "name": "entity.name.function.kinglet"
            }
          }
        },
        {
          "name": "meta.function.return-type.kinglet",
          "match": "\\b(int|float|double|bool|string|void|byte|auto)\\b(?=\\s+\\w+\\s*\\()"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.kinglet",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "namespace-access": {
      "patterns": [
        {
          "name": "meta.namespace.kinglet",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*::",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "entity.name.namespace.kinglet",
                  "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*::)"
                },
                {
                  "name": "keyword.operator.kinglet",
                  "match": "::"
                }
              ]
            }
          }
        }
      ]
    }
  }
}
